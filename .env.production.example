# OutreachOS Production Environment Template
# Copy values into Vercel Project Settings → Environment Variables (Production)

# Application
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
NEXT_PUBLIC_SITE_NAME=OutreachOS

# Supabase (production project: outreachos / qowwnchhyjnfovxcjiqw)
NEXT_PUBLIC_SUPABASE_URL=https://qowwnchhyjnfovxcjiqw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_production_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_production_service_role_key

# API Security
AGENT_SECRET=your_production_agent_secret_key_very_secure
ALLOWED_ORIGINS=https://chat.openai.com,https://chatgpt.com
API_KEYS=

# AES-256 key for MFA secrets at rest (server-only, never NEXT_PUBLIC_)
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_64_hex_chars

# Admin bootstrap (server-only — never NEXT_PUBLIC_)
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=change_me_strong_unique_production_password

# Monitoring & Observability
LOG_LEVEL=info
FEATURE_MFA_ENABLED=true
FEATURE_RATE_LIMITING=true
FEATURE_DETAILED_LOGGING=true

# Optional: external APM
# SENTRY_DSN=
# ANALYTICS_ID=
