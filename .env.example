# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_public_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# App / Auth URLs (required for password reset + OAuth/PKCE redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Supabase Dashboard → Authentication → URL Configuration should allow:
# Site URL: http://localhost:3000
# Redirect URLs:
#   http://localhost:3000/auth/callback
#   http://localhost:3000/auth/reset-password
#   http://localhost:3000/auth/login

# Local admin credentials (server-only — never prefix with NEXT_PUBLIC_)
ADMIN_EMAIL=nottech90@gmail.com
ADMIN_USERNAME=Admin
ADMIN_PASSWORD=change_me_strong_password

# Public demo account (limited role + curated lead sample)
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_USERNAME=DemoUser
DEMO_USER_PASSWORD=change_me_demo_password

# Agent API lead inserts attach to this user (defaults to ADMIN_EMAIL lookup)
# AGENT_LEAD_OWNER_ID=

# Legacy agent route only (ChatGPT intake was scrapped — Excel import is the product path)
AGENT_SECRET=your_secure_agent_secret_key

# AES-256 key for encrypting MFA secrets at rest (server-only).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Never commit the real value. Never prefix with NEXT_PUBLIC_.
ENCRYPTION_KEY=replace_with_64_hex_chars

# Optional: Google Search Console HTML-tag verification (content= value only)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Optional
ALLOWED_ORIGINS=https://chat.openai.com
API_KEYS=comma_separated_api_keys_for_bearer_auth
# Optional salt for hashing API_KEYS at runtime (falls back to ENCRYPTION_KEY)
# API_KEY_HASH_SALT=
LOG_LEVEL=info

# Admin management dashboard (Google-only allowlist)
# Falls back to ADMIN_EMAIL when unset. Case-insensitive match.
ADMIN_GOOGLE_EMAIL=nottech90@gmail.com

# Razorpay Subscriptions — PAUSED (no PAN/KYC yet). App uses email Premium requests instead.
# Keep keys empty until you re-enable online checkout.
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
# RAZORPAY_PLAN_ID_INR=
# RAZORPAY_PLAN_ID_USD=

# Production feature flags (see also .env.production.example)
FEATURE_MFA_ENABLED=true
FEATURE_RATE_LIMITING=true
FEATURE_DETAILED_LOGGING=true

# Auth setup notes:
# - Enable Email confirmations in Supabase → Authentication → Providers → Email
# - Enable Google provider and add Client ID / Secret from Google Cloud Console
# - Enable Automatic Linking (verified emails) so Google + email/password merge
# - Redirect URLs must include /auth/callback (and production domain equivalents)
# - Apply supabase/migrations/005_leads_owner_isolation.sql for per-user lead pools
# - Apply supabase/migrations/009_subscriptions.sql for Premium billing
# - Free accounts: 500 leads, 10 imports/day, 200 rows/import
# - Premium: unlimited leads, 30 files/hour, 3000 rows/hour (₹1499 or $15)
# - One-time identity merge (if duplicate Google user exists):
#     node --env-file=.env.local scripts/merge-auth-identities.mjs --dry-run
#     node --env-file=.env.local scripts/merge-auth-identities.mjs --email=you@example.com
# - Admin management UI: /admin/management-dashboard (Google + ADMIN_GOOGLE_EMAIL only)

# Production deployment notes:
# - Copy .env.production.example values into Vercel → Settings → Environment Variables
# - Update Supabase Auth Site URL + Redirect URLs to the production domain
# - Set NEXT_PUBLIC_APP_URL / SITE_URL to https://outreachos.techxtreme.me (canonical)
# - Run: npm run ensure:accounts && npm run seed:demo after first production deploy
# - Apply supabase/migrations/003_production_observability.sql if not yet applied
# - Apply supabase/migrations/004_demo_sample_leads.sql for demo showcase scoping
# - NEVER commit .env.local or real passwords
# - SEO: /robots.txt, /sitemap.xml, /llms.txt ship with the app; submit sitemap in Search Console
