# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_public_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# App / Auth URLs (required for password reset + OAuth/PKCE redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Supabase Dashboard → Authentication → URL Configuration should allow:
# Site URL: http://localhost:3000
# Redirect URLs:
#   http://localhost:3000/auth/callback
#   http://localhost:3000/auth/reset-password
#   http://localhost:3000/auth/login

# Local admin credentials (server-only — never prefix with NEXT_PUBLIC_)
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=Admin
ADMIN_PASSWORD=change_me_strong_password

# Public demo account (limited role + curated lead sample)
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_USERNAME=DemoUser
DEMO_USER_PASSWORD=change_me_demo_password

# ChatGPT Agent API
AGENT_SECRET=your_secure_agent_secret_key

# Optional
ALLOWED_ORIGINS=https://chat.openai.com
API_KEYS=comma_separated_api_keys_for_bearer_auth
LOG_LEVEL=info

# Production feature flags (see also .env.production.example)
FEATURE_MFA_ENABLED=true
FEATURE_RATE_LIMITING=true
FEATURE_DETAILED_LOGGING=true

# Production deployment notes:
# - Copy .env.production.example values into Vercel → Settings → Environment Variables
# - Update Supabase Auth Site URL + Redirect URLs to the production domain
# - Run: npm run ensure:accounts && npm run seed:demo after first production deploy
# - Apply supabase/migrations/003_production_observability.sql if not yet applied
# - Apply supabase/migrations/004_demo_sample_leads.sql for demo showcase scoping
# - NEVER commit .env.local or real passwords
