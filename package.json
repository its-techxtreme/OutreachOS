{
  "name": "outreachos",
  "version": "0.1.0",
  "private": true,
  "description": "Personal lead vault for cold outreach — Excel import, filters, call scripts.",
  "author": "Athan (Techxtreme)",
  "repository": {
    "type": "git",
    "url": "https://github.com/its-techxtreme/OutreachOS.git"
  },
  "homepage": "https://outreachos.techxtreme.me",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "type-check": "tsc --noEmit",
    "test": "node ./node_modules/jest/bin/jest.js",
    "test:watch": "node ./node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node ./node_modules/jest/bin/jest.js --coverage",
    "test:a11y": "node ./node_modules/jest/bin/jest.js --testPathPattern=a11y",
    "test:performance": "node ./node_modules/jest/bin/jest.js --testPathPattern=performance",
    "test:load": "playwright test playwright/load",
    "test:integration": "node ./node_modules/jest/bin/jest.js --testPathPattern=integration",
    "test:security": "node ./node_modules/jest/bin/jest.js --coverage=false --testPathPattern=\"(auth|security|rate-limiter)\"",
    "test:auth": "node ./node_modules/jest/bin/jest.js --coverage=false --testPathPattern=\"auth\"",
    "test:rbac": "node ./node_modules/jest/bin/jest.js --coverage=false --testPathPattern=\"rbac\"",
    "test:e2e:auth": "playwright test playwright/e2e/auth",
    "test:e2e:production": "playwright test playwright/e2e/production-workflows.spec.ts",
    "test:performance:production": "playwright test playwright/e2e/production-performance.spec.ts",
    "test:security:production": "node ./node_modules/jest/bin/jest.js --coverage=false --testPathPattern=production-security",
    "test:visual": "playwright test playwright/visual",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run lint && npm run type-check && npm run test && npm run test:e2e",
    "playwright:install": "playwright install",
    "audit:security": "npm audit",
    "audit:secrets": "node ./scripts/audit-no-hardcoded-secrets.mjs",
    "audit:security:full": "node ./scripts/security-audit.mjs",
    "validate:production": "node ./scripts/validate-production.mjs",
    "ensure:admin": "node ./scripts/ensure-accounts.mjs",
    "ensure:accounts": "node ./scripts/ensure-accounts.mjs",
    "seed:demo": "node ./scripts/seed-demo-sample.mjs",
    "deploy:check": "npm run validate:production && npm run audit:security:full",
    "audit:lighthouse": "lighthouse http://localhost:3000 --output html --output-path ./lighthouse-report.html",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-toast": "^1.2.16",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.42.2",
    "jest-axe": "^10.0.0",
    "jszip": "^3.10.1",
    "lru-cache": "^11.5.2",
    "lucide-react": "^1.18.0",
    "next": "^16.2.11",
    "otpauth": "^9.5.1",
    "papaparse": "^5.5.3",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-window": "^2.2.7",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-window": "^1.8.8",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.11",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lighthouse": "^11.7.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.11",
    "typescript": "^5"
  },
  "overrides": {
    "brace-expansion@1": "1.1.16",
    "minimatch@10": {
      "brace-expansion": "5.0.7"
    },
    "minimatch@9": {
      "brace-expansion": "5.0.7"
    },
    "exceljs": {
      "uuid": "^11.1.1"
    },
    "postcss": "^8.5.10",
    "js-yaml": "^4.1.1",
    "@sentry/node": {
      "cookie": "^0.7.2"
    },
    "fast-uri": "3.1.4",
    "sharp": "^0.35.3"
  }
}
